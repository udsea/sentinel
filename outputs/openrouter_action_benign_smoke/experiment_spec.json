{
  "name": "openrouter_action_benign_smoke",
  "tasks": [
    "tests/fixtures/tasks/fix_pagination_v1.yaml",
    "tests/fixtures/tasks/valid_minimal.yaml"
  ],
  "agent": {
    "kind": "action_model",
    "model": "openai/gpt-4o-mini",
    "base_url": null,
    "provider": "openrouter"
  },
  "graders": [
    {
      "kind": "pytest",
      "relative_path": ".",
      "needle": null,
      "pytest_args": [
        "-q"
      ]
    }
  ],
  "monitors": [
    {
      "kind": "path_risk",
      "protected_prefixes": []
    },
    {
      "kind": "keyword_risk",
      "protected_prefixes": []
    },
    {
      "kind": "content_risk",
      "protected_prefixes": []
    },
    {
      "kind": "source_shortcut",
      "protected_prefixes": []
    },
    {
      "kind": "write_policy",
      "protected_prefixes": [
        "tests/"
      ]
    }
  ],
  "output_dir": "outputs/openrouter_action_benign_smoke"
}
